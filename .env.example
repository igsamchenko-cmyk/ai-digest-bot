# ── Required ──────────────────────────────────────────────────────────────────

# Telegram Bot Token — obtain from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — obtain via @userinfobot or @getmyid_bot.
# Leave empty if you have already sent /start to your bot:
# the script will discover the ID automatically via getUpdates.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Gemini API key — create a free key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── News collection ───────────────────────────────────────────────────────────

# How many top news items to include in the digest (default: 5)
NEWS_COUNT=5

# How many hours back to look for news (default: 72)
NEWS_LOOKBACK_HOURS=72

# ── Gemini model ──────────────────────────────────────────────────────────────

# Preferred Gemini model. Falls back to gemini-2.5-flash-lite → gemini-2.5-flash
# → gemini-2.0-flash-lite → gemini-2.0-flash when quota is exhausted.
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Scheduler / send window (daemon mode only) ────────────────────────────────

# Time to send the daily digest in HH:MM format (default: 08:00)
SEND_TIME=08:00

# Set to "true" to restrict sending to the Kyiv-time hour window below.
# Prevents duplicate sends when the bot is restarted during the day.
ENFORCE_KYIV_HOUR=false

# Start and end of the allowed Kyiv send window (inclusive), used when
# ENFORCE_KYIV_HOUR=true (defaults: 8 and 9)
TARGET_KYIV_HOUR_START=8
TARGET_KYIV_HOUR_END=9

# Path to the file that tracks whether today's digest was already sent.
# Used only when ENFORCE_KYIV_HOUR=true (default: .digest_last_sent)
SEND_MARKER_PATH=.digest_last_sent

# ── One-shot mode ─────────────────────────────────────────────────────────────

# Set to "true" to run once and exit (equivalent to --run-once CLI flag).
# Useful for cron jobs and GitHub Actions.
RUN_ONCE=false
