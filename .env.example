# Telegram Configuration
# РћС‚СЂРёРјР°Р№С‚Рµ С‚РѕРєРµРЅ Сѓ @BotFather РІ Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# РћС‚СЂРёРјР°Р№С‚Рµ СЃРІС–Р№ ID, РЅР°РїСЂРёРєР»Р°Рґ, С‡РµСЂРµР· Р±РѕС‚ @userinfobot
# РњРѕР¶РЅР° Р·Р°Р»РёС€РёС‚Рё РїРѕСЂРѕР¶РЅС–Рј, СЏРєС‰Рѕ РІРё РЅР°РїРёСЃР°Р»Рё СЃРІРѕС”РјСѓ Р±РѕС‚Сѓ /start:
# СЃРєСЂРёРїС‚ СЃРїСЂРѕР±СѓС” РІРёР·РЅР°С‡РёС‚Рё chat id С‡РµСЂРµР· Telegram getUpdates.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Gemini API Configuration
# РћС‚СЂРёРјР°Р№С‚Рµ РєР»СЋС‡ Сѓ Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
USE_GEMINI=true  # set false for RSS-only mode without Gemini API calls

# Optional
# NEWS_COUNT: items sent in the Gemini-curated digest (AI selection + summaries).
NEWS_COUNT=10
# RSS_FALLBACK_NEWS_COUNT: items sent when Gemini is unavailable (titles + links only).
# Default: same as NEWS_COUNT.
RSS_FALLBACK_NEWS_COUNT=10
NEWS_LOOKBACK_HOURS=72
GEMINI_MODEL=gemini-2.0-flash
DIGEST_TOPIC=artificial intelligence, LLM models, AI companies, machine learning, new AI releases
