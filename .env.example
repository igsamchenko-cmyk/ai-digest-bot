# Telegram Configuration
# Отримайте токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Отримайте свій ID, наприклад, через бот @userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Gemini API Configuration
# Отримайте ключ у Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional
NEWS_COUNT=5
GEMINI_MODEL=gemini-2.0-flash
DIGEST_TOPIC=artificial intelligence, LLM models, AI companies, machine learning, new AI releases
